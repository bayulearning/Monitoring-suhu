generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model monitoring_logs {
  id          Int       @id @default(autoincrement())
  temperature Float
  humidity    Float
  status      String    @db.VarChar(20)
  created_at  DateTime @default(now()) @db.Timestamp(6)
}
